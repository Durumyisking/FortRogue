{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__ue-mcp__(editor|tools)",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/post-tool-use.mjs\"",
            "timeout": 30,
            "statusMessage": "Checking for a ue-mcp native-tool gap"
          }
        ]
      }
    ]
  }
}
